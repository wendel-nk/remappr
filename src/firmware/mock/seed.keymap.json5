{
    // ─── remappr generalized keymap (demo seed) ──────────────────────────────
    // SOURCE OF TRUTH for the demo device. The user edits this; remappr compiles
    // it to ZMK / QMK(VIA) / Keychron at export. No firmware syntax is stored here.
    //
    // Conventions:
    //  • bindings are ARRAYS — a binding's position is its index, lined up 1:1
    //    with keyboard.keys (validated by length).
    //  • keycodes are neutral names resolved against the canonical catalog, so the
    //    same name works on every backend.
    //  • type names describe BEHAVIOR, not a firmware. Friendly presets: mod_tap
    //    (tap = key, hold = modifier), layer_tap (tap = key, hold = layer).
    //  • app-visible notes live in `description` fields, NOT comments — comments
    //    are dropped when remappr re-saves the file.

    schemaVersion: 1,
    kind: 'remappr.keymap',

    meta: {
        name: 'Mock Split 12+2',
        author: 'remappr',
        version: '1.0.0',
        description: '12-key grid + 2 rotated thumbs + a knob. The demo device.',
        target: null, // null = firmware-agnostic. Set "zmk"|"qmk"|"keychron" to pin.
    },

    defaults: {
        tappingTermMs: 200,
        quickTapMs: 150,
        comboTimeoutMs: 50,
    },

    keyboard: {
        id: 'mock_split_12_2',
        name: 'Mock Split 12+2',
        keys: [
            { x: 0, y: 0 },
            { x: 1, y: 0 },
            { x: 2, y: 0 },
            { x: 3, y: 0 }, //  0..3
            { x: 0, y: 1 },
            { x: 1, y: 1 },
            { x: 2, y: 1 },
            { x: 3, y: 1 }, //  4..7
            { x: 0, y: 2 },
            { x: 1, y: 2 },
            { x: 2, y: 2 },
            { x: 3, y: 2 }, //  8..11
            { x: 1.25, y: 3, w: 1.25, h: 1, r: 20, rx: 1.25, ry: 3 }, // 12 (L thumb)
            { x: 2.75, y: 3, w: 1.25, h: 1, r: -20, rx: 2.75, ry: 3 }, // 13 (R thumb)
        ],
        encoders: [
            { x: 5, y: 0 }, // encoder 0
        ],
    },

    layers: [
        {
            name: 'base',
            description: 'Default layer.',
            bindings: [
                'Q',
                'W',
                'E',
                'R',
                'A',
                'S',
                'D',
                'F',
                'Z',
                'X',
                'C',
                'V',
                // L thumb: tap = Space, hold = the "lower" layer (Layer-Tap preset)
                {
                    type: 'layer_tap',
                    tap: 'SPACE',
                    layer: 'lower',
                    resolve: 'prefer-hold',
                }, // 12
                // R thumb: tap = Enter, hold = Left Shift (Mod-Tap preset)
                {
                    type: 'mod_tap',
                    tap: 'ENTER',
                    mod: 'LEFT_SHIFT',
                    resolve: 'prefer-hold',
                }, // 13
            ],
            encoders: [
                { cw: 'Volume Up', ccw: 'Volume Down' }, // encoder 0
            ],
        },

        {
            name: 'lower',
            description: 'Numbers, navigation, editing (held via the left thumb).',
            bindings: [
                'N1',
                'N2',
                'N3',
                { type: 'layer', mode: 'momentary', layer: 'adjust' }, // 3
                'LEFT',
                'DOWN',
                'UP',
                'RIGHT',
                'Ctrl+C', // 8  copy
                'Ctrl+V', // 9  paste
                { type: 'caps_word' }, // 10
                { type: 'tap_dance', ref: 'esc_grave' }, // 11
                { type: 'transparent' }, // 12 (this is the hold key)
                { type: 'transparent' }, // 13
            ],
            encoders: [{ cw: 'PAGE_DOWN', ccw: 'PAGE_UP' }],
        },

        {
            name: 'adjust',
            description: 'Device controls — exercises firmware-gated features.',
            bindings: [
                { type: 'output', action: 'usb' }, // 0
                { type: 'output', action: 'bluetooth', profile: 0 }, // 1  zmk ok, qmk warns
                { type: 'output', action: 'bluetooth', profile: 1 }, // 2
                { type: 'output', action: 'bluetooth_clear' }, // 3
                { type: 'lighting', target: 'underglow', action: 'toggle' }, // 4
                {
                    type: 'lighting',
                    target: 'underglow',
                    action: 'brightness_up',
                }, // 5
                {
                    type: 'lighting',
                    target: 'underglow',
                    action: 'brightness_down',
                }, // 6
                { type: 'lighting', target: 'per_key', action: 'effect_next' }, // 7
                { type: 'bootloader' }, // 8
                { type: 'reset' }, // 9
                { type: 'none' }, // 10 explicitly inert (blocks fall-through)
                { type: 'macro', ref: 'lock_screen' }, // 11
                { type: 'transparent' }, // 12
                { type: 'layer', mode: 'toggle', layer: 'adjust' }, // 13
            ],
            encoders: [
                {
                    cw: {
                        type: 'lighting',
                        target: 'underglow',
                        action: 'brightness_up',
                    },
                    ccw: {
                        type: 'lighting',
                        target: 'underglow',
                        action: 'brightness_down',
                    },
                },
            ],
        },
    ],

    combos: [
        {
            name: 'esc',
            keys: [0, 1], // Q + W
            action: 'ESCAPE',
            timeoutMs: 50,
            layers: ['base'],
        },
        {
            name: 'tab',
            keys: [4, 5], // A + S
            action: 'TAB',
        },
    ],

    tapDances: [
        {
            id: 'esc_grave',
            description: '1 tap = Esc, 2 taps = grave, hold = Left GUI.',
            tappingTermMs: 200,
            taps: [
                { count: 1, action: 'ESCAPE' },
                { count: 2, action: 'GRAVE' },
            ],
            hold: { type: 'modifier', modifier: 'LEFT_GUI' },
        },
    ],

    macros: [
        {
            id: 'lock_screen',
            description: 'Hold GUI, tap L, release GUI (lock the screen).',
            steps: [
                { type: 'press', key: 'LEFT_GUI' },
                { type: 'tap', key: 'L' },
                { type: 'release', key: 'LEFT_GUI' },
            ],
        },
    ],
}
