{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/shared/**/*",
    "src/firmware/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "baseUrl": ".",
    "allowImportingTsExtensions": true,
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@/*": ["src/renderer/src/*"],
      "@firmware": ["src/firmware"],
      "@firmware/*": ["src/firmware/*"],
      "@shared/*": ["src/shared/*"]
    }
  }
}
