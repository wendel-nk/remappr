{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/shared/**/*",
    "src/firmware/**/*"
  ],
  "exclude": [
    "node_modules",
    "out-types",
    "**/*.stories.ts",
    "**/*.stories.tsx"
  ],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "outDir": "./out-types/web",
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "baseUrl": ".",
    "allowImportingTsExtensions": true,
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@/*": ["src/renderer/src/*"],
      "@firmware": ["src/firmware"],
      "@firmware/*": ["src/firmware/*"],
      "@shared/*": ["src/shared/*"],
      "lzma1": ["src/firmware/qmk-vial/lzma1.d.ts"]
    }
  }
}
