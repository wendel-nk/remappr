{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitAny": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@firmware": ["./src/firmware"],
      "@firmware/*": ["./src/firmware/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": [
    "vite.config.ts",
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "src/firmware/**/*"
  ],
  "exclude": [
    "src/firmware/zmk/**"
  ]
}
