{
    "name": "remappr",
    "private": true,
    "version": "0.0.8",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./out/main/index.js",
    "packageManager": "pnpm@10.30.3",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "lint": "eslint . --report-unused-disable-directives",
        "preview": "vite preview",
        "storybook": "storybook dev -p 6006",
        "estart": "electron-vite preview",
        "edev": "electron-vite dev",
        "ebuild": "pnpm typecheck && electron-vite build",
        "format": "prettier --write .",
        "build-storybook": "storybook build",
        "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
        "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
        "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
        "prepare": "husky",
        "postinstall": "electron-builder install-app-deps",
        "build:unpack": "electron-vite build && electron-builder --dir --config electron-builder.config.cjs",
        "build:win": "electron-vite build && electron-builder --win --publish never --config electron-builder.config.cjs",
        "build:mac": "electron-vite build && electron-builder --mac --publish never --config electron-builder.config.cjs",
        "build:linux": "electron-vite build && electron-builder --linux --publish never --config electron-builder.config.cjs",
        "test": "vitest run",
        "test:watch": "vitest",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs"
    },
    "dependencies": {
        "node-hid": "^3.3.0",
        "serialport": "^13.0.0"
    },
    "optionalDependencies": {
        "dbus-next": "^0.10.2"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^5.0.0",
        "@commitlint/cli": "^19.6.1",
        "@commitlint/config-conventional": "^19.6.0",
        "@electron-toolkit/eslint-config-prettier": "^3.0.0",
        "@electron-toolkit/eslint-config-ts": "^3.1.0",
        "@electron-toolkit/preload": "^3.0.2",
        "@electron-toolkit/tsconfig": "^2.0.0",
        "@electron-toolkit/utils": "^4.0.0",
        "@monaco-editor/react": "^4.7.0",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-hover-card": "^1.1.15",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-slot": "^1.2.4",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@storybook/addon-links": "^10.2.3",
        "@storybook/addon-onboarding": "^10.2.3",
        "@storybook/react": "^10.2.3",
        "@storybook/react-vite": "^10.2.3",
        "@tailwindcss/container-queries": "^0.1.1",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/postcss": "^4.1.18",
        "@tailwindcss/vite": "^4.1.18",
        "@types/node": "^25.2.0",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@types/w3c-web-hid": "^1.0.7",
        "@types/w3c-web-serial": "^1.0.8",
        "@types/w3c-web-usb": "^1.0.14",
        "@types/web-bluetooth": "^0.0.21",
        "@typescript-eslint/eslint-plugin": "^8.54.0",
        "@typescript-eslint/parser": "^8.54.0",
        "@vitejs/plugin-react-swc": "^4.2.2",
        "@zmkfirmware/zmk-studio-ts-client": "^0.0.18",
        "autoprefixer": "^10.4.24",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "electron": "^39.2.6",
        "electron-builder": "^26.0.12",
        "electron-vite": "^5.0.0",
        "eslint": "^9.39.1",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "eslint-plugin-storybook": "^10.2.3",
        "husky": "^9.1.7",
        "immer": "^11.1.3",
        "lint-staged": "^16.1.0",
        "lucide-react": "^1.11.0",
        "lzma1": "^0.3.0",
        "monaco-editor": "^0.55.1",
        "next-themes": "^0.4.6",
        "postcss": "^8.5.6",
        "prettier": "^3.7.4",
        "react": "^19.2.1",
        "react-aria-components": "^1.14.0",
        "react-dom": "^19.2.4",
        "run-script-os": "^1.1.6",
        "sonner": "^2.0.7",
        "storybook": "^10.2.3",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^4.1.18",
        "tailwindcss-react-aria-components": "^2.0.1",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "vaul": "^1.1.2",
        "vite": "^7.2.6",
        "vitepress": "^1.6.4",
        "vitest": "^3.2.4",
        "zod": "^4.4.3",
        "zustand": "^5.0.11"
    },
    "overrides": {
        "rimraf": "^5.0.10",
        "glob": "^13.0.0",
        "tar": "^7.5.11",
        "uuid": "^11.0.3",
        "form-data": "^2.5.4",
        "xml2js": "^0.6.2",
        "tough-cookie": "^4.1.4",
        "qs": "^6.14.1",
        "node-addon-api": "^8.8.0"
    },
    "pnpm": {
        "overrides": {
            "tar": "^7.5.11",
            "form-data": "^2.5.4",
            "xml2js": "^0.6.2",
            "tough-cookie": "^4.1.4",
            "qs": "^6.14.1",
            "node-addon-api": "^8.8.0"
        },
        "patchedDependencies": {
            "usocket@0.3.0": "patches/usocket@0.3.0.patch"
        },
        "onlyBuiltDependencies": [
            "electron",
            "electron-winstaller",
            "esbuild",
            "@swc/core",
            "@serialport/bindings-cpp",
            "node-hid",
            "usocket",
            "protobufjs",
            "@zmkfirmware/zmk-studio-ts-client"
        ]
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix --no-warn-ignored",
            "prettier --write"
        ],
        "*.{js,mjs,cjs}": [
            "eslint --fix --no-warn-ignored",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml,css}": [
            "prettier --write"
        ]
    }
}
